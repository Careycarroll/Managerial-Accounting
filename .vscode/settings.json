{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.tabSize": 2,
  "files.associations": {
    "*.css": "css",
    "*.js": "javascript"
  },
  "emmet.includeLanguages": {
    "javascript": "html"
  },
  "css.customData": [".vscode/css-custom-data.json"]
}
